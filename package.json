		"test": "vitest run"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/ui": "^4.1.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.101.0",
		"@tailwindcss/vite": "^4.2.2",
		"date-fns": "^4.1.0",
		"lucide-svelte": "^1.0.1",
		"svelte-dnd-action": "^0.9.69",
		"svelte-sonner": "^1.1.0",
		"tailwindcss": "^4.2.2"
	},
